# ─── Gemini API Keys (add as many as you have — auto-rotation handles rate limits) ───
GEMINI_API_KEY=your_primary_key_here
GEMINI_API_KEY_1=your_second_key_here
GEMINI_API_KEY_2=your_third_key_here
GEMINI_API_KEY_3=your_fourth_key_here
GEMINI_API_KEY_4=your_fifth_key_here
GEMINI_API_KEY_5=your_sixth_key_here
GEMINI_API_KEY_6=your_seventh_key_here
GEMINI_API_KEY_7=your_eighth_key_here
GEMINI_API_KEY_8=your_ninth_key_here
GEMINI_API_KEY_9=your_tenth_key_here

# ─── App Security ──────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-long-random-string-here

# ─── Database ──────────────────────────────────────────────────────────────────
# Local dev: SQLite (no config needed)
DATABASE_URL=sqlite:///./fairlens.db

# Neon PostgreSQL (for Render/production):
# DATABASE_URL=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/fairlens?sslmode=require

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local:
ALLOWED_ORIGINS=http://localhost:3000
# Production (comma-separated):
# ALLOWED_ORIGINS=https://fairlens.vercel.app,https://fairlens-frontend.onrender.com
